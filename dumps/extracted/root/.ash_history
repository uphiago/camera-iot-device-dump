ifconfig 
mount -t nfs -o nolock 192.168.1.4:/home/guest/nfs /mnt/nfs
cd /mnt/nfs/
rm flash16MGoke.bin 
cat /dev/mtd4 >/mnt/nfs/flash16MGoke.bin
id
cat /etc/shadow
kill -9 1553; echo 'kill: '$?
rm -f /tmp/dl /tmp/r /bin/omm /tmp/omm; echo 'rm: '$?
ls -la /tmp/dl /tmp/r 2>&1
passwd root
ps | grep -E 'tmp/r|tmp/dl|omm|ftpget' | grep -v grep
id
killall -9 ftpget omm 2>/dev/null; echo 'done'
sed -i 's|root:[^:]*|root:x0uWZqB0iTVNs|' /etc/shadow
sed -i 's|admin:[^:]*|admin:x0uWZqB0iTVNs|' /etc/shadow
cat /etc/shadow | grep '^root:'
rm -f /tmp/r /tmp/dl /bin/omm /tmp/omm 2>/dev/null; echo 'done'
ps | grep ftpget | grep -v grep
cat /mnt/mtd/ipc/conf/config_debug.ini
grep telnetd /mnt/mtd/ipc/run
id
cat /etc/shadow
cat /etc/passwd
cat /mnt/mtd/ipc/conf/config_debug.ini
cat /mnt/mtd/ipc/conf/config_user.ini
cat /mnt/mtd/ipc/conf/config_net.ini
cat /mnt/mtd/ipc/conf/config_platform.ini
cat /mnt/mtd/ipc/conf/config_sysinfo.ini
cat /mnt/mtd/ipc/run
cat /etc/init.d/S98test
ls -la /tmp/r /tmp/dl /bin/omm 2>&1
ls -la /etc/init.d/
ls /etc/cron* /var/spool/cron* 2>/dev/null; cat /etc/crontab 2>/dev/null
cat /etc/inittab
ps | grep -v ipc_server | grep -v ' 0:00'
find /bin /sbin /usr /tmp /root /home -name 'omm*' -o -name 'mips' -o -name 'arm' -o -name 'bot' 2>/dev/null | head -10
dmesg | tail -30
ls -la /mnt/mtd/ipc/tmpfs/
cat /mnt/mtd/ipc/tmpfs/syslog.txt
cat /proc/mtd
df -h
cat /proc/partitions
mount
ls -la /dev/mtd*
ls -la /dev/mtdblock* 2>/dev/null || echo 'none'
du -sh / 2>/dev/null
du -sh /bin /lib /usr /etc /mnt 2>/dev/null
which tar nc dd 2>/dev/null; ls /bin/busybox 2>/dev/null; busybox --list 2>/dev/null | head -30
free
busybox 2>/dev/null | head -5
which tar 2>/dev/null
which nc 2>/dev/null
which dd 2>/dev/null
ls -la /bin/tar /bin/nc /bin/dd 2>/dev/null
busybox tar 2>&1 | head -3
busybox nc 2>&1 | head -3
busybox dd 2>&1 | head -3
exit
busybox --list 2>/dev/null
ls /bin/ | tr ' ' '
' | sort
ls /usr/bin/ 2>/dev/null | sort
ls /sbin/ 2>/dev/null | sort
exit
df -h /tmp
du -sh / --exclude=/proc --exclude=/sys --exclude=/dev --exclude=/tmp --exclude=/mnt 2>/dev/null
ls -la /tmp/
exit
cat /tmp/create_omm.sh
ls -la /tmp/
ps
exit
tar --help 2>&1
gzip --help 2>&1
which zcat gzip 2>/dev/null
exit
du -sh /* 2>/dev/null
tar czf /tmp/rootfs.tar.gz /bin /etc /lib /root /sbin /usr /home /init 2>&1
ls -la /tmp/rootfs.tar.gz
df -h /tmp
exit
rm -f /tmp/rootfs.tar.gz 2>/dev/null
tar czf /tmp/rootfs.tar.gz /bin /etc /lib /root /sbin /usr /var 2>/dev/null; echo DONE
echo READY
ls -lh /tmp/*.tar.gz /tmp/*.bin 2>/dev/null
wc -c /tmp/rootfs.tar.gz
wc -c /tmp/uboot.bin /tmp/ubootenv.bin /tmp/kernel.bin /tmp/rootfs_flash.bin 2>/dev/null
df -h /tmp
exit
echo ---; ls -lh /tmp/; echo ---; wc -c /tmp/rootfs.tar.gz /tmp/uboot.bin /tmp/ubootenv.bin /tmp/kernel.bin /tmp/rootfs_flash.bin 2>/dev/null
tar tzf /tmp/rootfs.tar.gz 2>&1 | tail -5; echo TAR_EXIT:$?
exit
echo '#!/bin/sh' >> /tmp/dump.sh
echo '# Dump script - saves to SD card (plenty of space)' >> /tmp/dump.sh
echo 'DST=/mnt/mtd/ipc/tmpfs/sd/dumps' >> /tmp/dump.sh
echo 'mkdir -p $DST' >> /tmp/dump.sh
echo 'echo "=== Starting dumps to $DST ==="' >> /tmp/dump.sh
echo '' >> /tmp/dump.sh
echo '# 1. Rootfs tar (no compression - gzip separately if needed)' >> /tmp/dump.sh
echo 'echo "[1/5] Creating rootfs tar..."' >> /tmp/dump.sh
echo 'tar cf $DST/rootfs.tar /bin /etc /lib /root /sbin /usr /var 2>/dev/null' >> /tmp/dump.sh
echo 'echo "rootfs.tar: $(wc -c < $DST/rootfs.tar) bytes"' >> /tmp/dump.sh
echo '' >> /tmp/dump.sh
echo '# 2. Raw flash dumps' >> /tmp/dump.sh
echo 'echo "[2/5] Dumping uboot (256KB)..."' >> /tmp/dump.sh
echo 'cat /dev/mtdblock0 > $DST/mtd0_uboot.bin' >> /tmp/dump.sh
echo 'echo "mtd0: $(wc -c < $DST/mtd0_uboot.bin) bytes"' >> /tmp/dump.sh
echo '' >> /tmp/dump.sh
echo 'echo "[3/5] Dumping ubootenv (64KB)..."' >> /tmp/dump.sh
echo 'cat /dev/mtdblock1 > $DST/mtd1_ubootenv.bin' >> /tmp/dump.sh
echo 'echo "mtd1: $(wc -c < $DST/mtd1_ubootenv.bin) bytes"' >> /tmp/dump.sh
echo '' >> /tmp/dump.sh
echo 'echo "[4/5] Dumping kernel (1728KB)..."' >> /tmp/dump.sh
echo 'cat /dev/mtdblock2 > $DST/mtd2_kernel.bin' >> /tmp/dump.sh
echo 'echo "mtd2: $(wc -c < $DST/mtd2_kernel.bin) bytes"' >> /tmp/dump.sh
echo '' >> /tmp/dump.sh
echo 'echo "[5/5] Dumping rootfs flash (14MB)..."' >> /tmp/dump.sh
echo 'cat /dev/mtdblock3 > $DST/mtd3_rootfs.bin' >> /tmp/dump.sh
echo 'echo "mtd3: $(wc -c < $DST/mtd3_rootfs.bin) bytes"' >> /tmp/dump.sh
echo '' >> /tmp/dump.sh
echo '# 3. System info' >> /tmp/dump.sh
echo 'echo "=== System Info ===" > $DST/sysinfo.txt' >> /tmp/dump.sh
echo 'uname -a >> $DST/sysinfo.txt' >> /tmp/dump.sh
echo 'cat /proc/cpuinfo >> $DST/sysinfo.txt' >> /tmp/dump.sh
echo 'cat /proc/mtd >> $DST/sysinfo.txt' >> /tmp/dump.sh
echo 'cat /proc/partitions >> $DST/sysinfo.txt' >> /tmp/dump.sh
echo 'mount >> $DST/sysinfo.txt' >> /tmp/dump.sh
echo 'df -h >> $DST/sysinfo.txt' >> /tmp/dump.sh
echo 'free >> $DST/sysinfo.txt' >> /tmp/dump.sh
echo 'ps >> $DST/sysinfo.txt' >> /tmp/dump.sh
echo 'ifconfig >> $DST/sysinfo.txt' >> /tmp/dump.sh
echo 'netstat -tlnp 2>/dev/null >> $DST/sysinfo.txt' >> /tmp/dump.sh
echo 'ls -laR /etc/init.d/ >> $DST/sysinfo.txt' >> /tmp/dump.sh
echo 'echo "=== Config Files ===" >> $DST/sysinfo.txt' >> /tmp/dump.sh
echo 'cat /mnt/mtd/ipc/conf/config_*.ini 2>/dev/null >> $DST/sysinfo.txt' >> /tmp/dump.sh
echo 'echo "=== /etc/shadow ===" >> $DST/sysinfo.txt' >> /tmp/dump.sh
echo 'cat /etc/shadow >> $DST/sysinfo.txt' >> /tmp/dump.sh
echo 'echo "=== /etc/passwd ===" >> $DST/sysinfo.txt' >> /tmp/dump.sh
echo 'cat /etc/passwd >> $DST/sysinfo.txt' >> /tmp/dump.sh
echo '' >> /tmp/dump.sh
echo 'echo ""' >> /tmp/dump.sh
echo 'echo "=== DUMP COMPLETE ==="' >> /tmp/dump.sh
echo 'ls -lh $DST/' >> /tmp/dump.sh
echo 'echo "=== END ==="' >> /tmp/dump.sh
echo '' >> /tmp/dump.sh
chmod +x /tmp/dump.sh
/tmp/dump.sh 2>&1
